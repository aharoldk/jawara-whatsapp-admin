# ─── WAHA (WhatsApp HTTP API) ────────────────────────────────────────────────
WAHA_API_KEY=change_me_waha_api_key
WAHA_DASHBOARD_USERNAME=admin
WAHA_DASHBOARD_PASSWORD=change_me_dashboard_pass

# ─── n8n ─────────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change_me_n8n_pass
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=change_me_32char_encryption_key_here
N8N_GEMINI_API_KEY=change_me_google_gemini_api_key

# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGO_USERNAME=jawara
MONGO_PASSWORD=change_me_mongo_pass
# Used directly by the backend service (docker-compose substitutes the values above)
MONGO_URI=mongodb://jawara:change_me_mongo_pass@localhost:27017/jawara?authSource=admin

# ─── Backend API ──────────────────────────────────────────────────────────────
# All requests to Hapi must include header: x-api-key: <value>
BACKEND_API_KEY=change_me_backend_api_key

# ─── AI Provider (used inside n8n workflow credentials) ───────────────────────
# Add your key in n8n UI → Credentials → OpenAI or Google Gemini
# OPENAI_API_KEY=sk-...
# GOOGLE_GEMINI_API_KEY=...

# ─── Local dev overrides (when running backend outside Docker) ────────────────
PORT=4000
NODE_ENV=development
WAHA_BASE_URL=http://localhost:3000
WAHA_SESSION=default
