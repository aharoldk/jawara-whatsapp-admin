# Server Configuration
PORT=3000
NODE_ENV=development
API_PREFIX=/api

# Database Configuration
# For local development
DATABASE_URL=mongodb://localhost:27017/whatsapp_admin
# For Docker development
# DATABASE_URL=mongodb://admin:password123@localhost:27017/whatsapp_admin?authSource=admin
# For Docker production (inside container)
# DATABASE_URL=mongodb://admin:password123@mongodb:27017/whatsapp_admin?authSource=admin
DATABASE_NAME=whatsapp_admin

# JWT Configuration
JWT_SECRET=your-secret-key-change-this-in-production
JWT_EXPIRES_IN=24h

# WhatsApp API Configuration (WAHA)
# For local development (when WAHA runs in Docker)
WHATSAPP_API_URL=http://localhost:3001
# For Docker production (inside container)
# WHATSAPP_API_URL=http://waha:3000
WHATSAPP_API_KEY=

# Scheduler Configuration
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL=60000

# Reminder Configuration
REMINDER_ENABLED=true
REMINDER_INTERVAL=60000
MESSAGE_RATE_LIMIT=1000

